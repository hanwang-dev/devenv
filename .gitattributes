# Shell scripts must use LF — CRLF breaks shebangs on Linux/macOS
*.sh    text eol=lf
*.bash  text eol=lf

# Windows scripts keep CRLF
*.ps1   text eol=crlf
*.psm1  text eol=crlf
*.cmd   text eol=crlf
*.bat   text eol=crlf

# Config/text files: normalize to LF
*.json  text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
.gitconfig text eol=lf
.bashrc    text eol=lf
.zshrc     text eol=lf
